font-family = FiraCode Nerd Font Mono Ret
theme = Builtin Tango Dark
unfocused-split-opacity = 0.75
split-divider-color = #888888

keybind = shift+insert=paste_from_clipboard
keybind = ctrl+insert=copy_to_clipboard

keybind = ctrl+shift+j=goto_split:down
keybind = ctrl+shift+k=goto_split:up
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+l=goto_split:right

keybind = ctrl+shift+|=new_split:right
keybind = ctrl+shift+/=new_split:down

keybind = ctrl+shift+n=new_window

keybind = ctrl+shift+arrow_left=resize_split:left,20
keybind = ctrl+shift+arrow_right=resize_split:right,20
keybind = ctrl+shift+arrow_up=resize_split:up,10
keybind = ctrl+shift+arrow_down=resize_split:down,10

keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+]=next_tab
keybind = ctrl+shift+[=previous_tab

keybind = ctrl+shift+r=reload_config

keybind = ctrl+shift+backspace=close_surface

keybind = ctrl+shift+q>q=quit

keybind = ctrl+shift+==increase_font_size:1.5
keybind = ctrl+shift+-=decrease_font_size:1.5

custom-shader = shaders/warp.glsl
